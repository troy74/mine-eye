{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mine-eye/contracts/scene3d.tilebroker_response.v1.schema.json",
  "title": "scene3d.tilebroker_response.v1",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "provider_id",
    "provider_label",
    "bounds",
    "attribution"
  ],
  "properties": {
    "schema_id": { "const": "scene3d.tilebroker_response.v1" },
    "schema_version": { "const": 1 },
    "provider_id": { "type": "string" },
    "provider_label": { "type": "string" },
    "attribution": { "type": "string" },
    "image_url": { "type": ["string", "null"] },
    "image_url_candidates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tile_url_template": { "type": ["string", "null"] },
    "request_shape": { "type": "object" },
    "bounds": {
      "type": "object",
      "required": ["xmin", "xmax", "ymin", "ymax"],
      "properties": {
        "xmin": { "type": "number" },
        "xmax": { "type": "number" },
        "ymin": { "type": "number" },
        "ymax": { "type": "number" }
      }
    },
    "source_crs": { "type": "object" },
    "target_crs": { "type": "object" },
    "texture_mode": { "type": "string", "enum": ["single_image", "tile_template"] },
    "z_mode": { "type": "string", "enum": ["drape_on_surface", "flat"] },
    "quality_flags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cache": { "type": "object" },
    "effective_config": { "type": "object" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "aoi_source_used": { "type": "string" },
    "diagnostics": { "type": "object" },
    "display_contract": { "type": "object" }
  }
}
