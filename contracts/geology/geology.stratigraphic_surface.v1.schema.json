{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mine-eye/contracts/geology.stratigraphic_surface.v1.schema.json",
  "title": "geology.stratigraphic_surface.v1",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "crs",
    "surface_id",
    "formation",
    "surface_role",
    "mesh"
  ],
  "properties": {
    "schema_id": { "const": "geology.stratigraphic_surface.v1" },
    "schema_version": { "type": "integer", "const": 1 },
    "crs": {
      "type": "object",
      "required": ["epsg"],
      "properties": {
        "epsg": { "type": "integer" },
        "vertical_datum": { "type": "string" },
        "units": { "type": "string" }
      },
      "additionalProperties": true
    },
    "surface_id": { "type": "string" },
    "formation": { "type": "string" },
    "surface_role": {
      "type": "string",
      "enum": ["top_contact", "base_contact", "fault", "erosion", "reference"]
    },
    "formation_above": { "type": ["string", "null"] },
    "formation_below": { "type": ["string", "null"] },
    "mesh": {
      "type": "object",
      "required": ["vertices", "faces"],
      "properties": {
        "vertices": {
          "type": "array",
          "items": {
            "type": "array",
            "prefixItems": [
              { "type": "number" },
              { "type": "number" },
              { "type": "number" }
            ],
            "minItems": 3,
            "maxItems": 3
          }
        },
        "faces": {
          "type": "array",
          "items": {
            "type": "array",
            "prefixItems": [
              { "type": "integer", "minimum": 0 },
              { "type": "integer", "minimum": 0 },
              { "type": "integer", "minimum": 0 }
            ],
            "minItems": 3,
            "maxItems": 3
          }
        }
      },
      "additionalProperties": true
    },
    "bounds": { "type": "object" },
    "display_contract": {
      "type": "object",
      "properties": {
        "renderer": { "const": "mesh" },
        "display_pointer": {
          "enum": ["scene3d.surface_mesh", "scene3d.surface"]
        }
      },
      "additionalProperties": true
    },
    "provenance": { "type": "object" }
  },
  "additionalProperties": true
}
