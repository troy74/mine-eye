{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mine-eye/contracts/geology.interpolation_constraints.v1.schema.json",
  "title": "geology.interpolation_constraints.v1",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "crs",
    "contacts",
    "orientations"
  ],
  "properties": {
    "schema_id": { "const": "geology.interpolation_constraints.v1" },
    "schema_version": { "type": "integer", "const": 1 },
    "crs": {
      "type": "object",
      "required": ["epsg"],
      "properties": {
        "epsg": { "type": "integer" },
        "vertical_datum": { "type": "string" },
        "units": { "type": "string" }
      },
      "additionalProperties": true
    },
    "contacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["constraint_id", "formation", "contact_kind", "x", "y", "z"],
        "properties": {
          "constraint_id": { "type": "string" },
          "formation": { "type": "string" },
          "contact_kind": { "type": "string" },
          "formation_above": { "type": ["string", "null"] },
          "formation_below": { "type": ["string", "null"] },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "z": { "type": "number" },
          "source_kind": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "qa_flags": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "orientations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["constraint_id", "formation", "x", "y", "z", "pole_vector"],
        "properties": {
          "constraint_id": { "type": "string" },
          "formation": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "z": { "type": "number" },
          "pole_vector": {
            "type": "array",
            "prefixItems": [
              { "type": "number" },
              { "type": "number" },
              { "type": "number" }
            ],
            "minItems": 3,
            "maxItems": 3
          },
          "source_kind": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "qa_flags": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "diagnostics": { "type": "object" },
    "provenance": { "type": "object" }
  },
  "additionalProperties": true
}
