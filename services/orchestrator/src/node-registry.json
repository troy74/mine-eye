    {
      "kind": "heatmap_raster_tile_cache",
      "category": "transform",
      "label": "Heatmap raster tile cache",
      "role": "Transform · XY+measure points → pre-computed heatmap tile pyramid (IDW/nearest, LOD-aware, 2D + 3D drape)",
      "description": "Interpolates XY point data (IDW or nearest-neighbour) onto a raster grid using a k-d tree spatial index, renders it to a colour ramp image, then slices the result into a local XYZ tile pyramid for fast LOD-aware display in the 2D map viewer and 3D drape renderer. Base image resolution scales with max_zoom so tiles are native quality without upscaling. Tiles are encoded in parallel on the CPU thread pool and written concurrently. The style_hash covers both UI parameters and upstream data hashes so tiles are automatically invalidated when input data changes.",
      "menu": {
        "enabled": true,
        "order": 81
      },
      "ports": {
        "inputs": [
          {
            "id": "in",
            "label": "Input points",
            "semantic": "point_set"
          }
        ],
        "outputs": [
          {
            "id": "tile_manifest",
            "label": "Tile manifest",
            "semantic": "raster"
          },
          {
            "id": "imagery_drape",
            "label": "Imagery drape",
            "semantic": "raster"
          },
          {
            "id": "report",
            "label": "Cache report",
            "semantic": "semantic_json"
          }
        ]
      },
      "framework_group": "analytics",
      "submenu": "surface_interpolation",
      "plugin_source": "core"
    },
